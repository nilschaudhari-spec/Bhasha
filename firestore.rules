rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'xp', 'weeklyXp', 'streak', 'coins', 'dailyGoal', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 8 &&
             data.email is string && data.email.size() <= 200 &&
             data.xp is number &&
             data.weeklyXp is number &&
             data.streak is number &&
             data.coins is number &&
             data.dailyGoal is number &&
             data.createdAt is number &&
             data.updatedAt is number &&
             (data.get('displayName', '') is string) &&
             (data.get('currentCourseId', '') is string) &&
             (data.get('completedLessons', []) is list && data.get('completedLessons', []).size() <= 5000);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.auth.uid == userId &&
                       isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId &&
                       isValidUser(incoming()) &&
                       incoming().createdAt == existing().createdAt &&
                       (
                         incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'weeklyXp', 'streak', 'lastActiveDate', 'coins', 'dailyGoal', 'displayName', 'updatedAt', 'completedLessons', 'currentCourseId'])
                       );
    }

    function isValidVocabularyItem(data) {
      return data.keys().hasAll(['userId', 'languageId', 'word', 'translation', 'srsStage', 'nextReviewDate', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 8 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.languageId is string && data.languageId.size() <= 50 &&
             data.word is string && data.word.size() <= 200 &&
             data.translation is string && data.translation.size() <= 200 &&
             data.srsStage is number &&
             data.nextReviewDate is number &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    match /vocabulary/{itemId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                       isValidVocabularyItem(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid &&
                       isValidVocabularyItem(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       (
                         incoming().diff(existing()).affectedKeys().hasOnly(['srsStage', 'nextReviewDate', 'updatedAt'])
                       );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
